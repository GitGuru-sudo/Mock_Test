# Server port (default: 5000)
PORT=5000

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_atlas_uri_here

# Upstash Redis REST credentials (from Upstash dashboard → REST API section)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# JWT secrets — must be at least 32 random characters each
# Tip: generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_jwt_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars_here

# Frontend origin for CORS (Vite dev server default)
CLIENT_URL=http://localhost:5173

# Node environment: development | production | test
NODE_ENV=development
